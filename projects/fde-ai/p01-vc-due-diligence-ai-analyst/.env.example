# Copy to .env and fill in values. Never commit .env.

# LLM API
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Cloud storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
